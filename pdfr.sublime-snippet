<snippet>
  <content><![CDATA[
#set page(margin:0pt) // remove margins for the PDF section
#for p in range(${2:first_page_in_range}, ${3:first_page_in_range}) {
  image("img/${1:document}.pdf", page: p, width:100%)
}
]]></content>
  <tabTrigger>pdfr</tabTrigger>
  <scope>text.typst</scope>
  <description>Insert PDF pages in a range</description>
</snippet>
